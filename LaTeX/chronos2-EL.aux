\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces  \small  UV vs.\ MV comparison by series (lower is better). Improvements are mean UV error minus mean MV error. Results are averaged across values of input length $n=\{126, 252, 504, 756\}$, and forecast period $m=\{21, 63\}$. Data for the rolling periods is from 2000 through 2025. Predictions periods begin 3 years after the start of the dataset. }}{4}{table.2}\protected@file@percent }
\newlabel{tab:uv-mv-comparison}{{2}{4}{\small UV vs.\ MV comparison by series (lower is better). Improvements are mean UV error minus mean MV error. Results are averaged across values of input length $n=\{126, 252, 504, 756\}$, and forecast period $m=\{21, 63\}$. Data for the rolling periods is from 2000 through 2025. Predictions periods begin 3 years after the start of the dataset}{table.2}{}}
\@writefile{toc}{\contentsline {section}{\numberline {4}Concluding Discussion}{4}{section.4}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces  \small  Combined dataset forecasts. UV vs.\ MV comparison by series (lower is better). Improvements are mean UV error minus mean MV error. Results are averaged across values of input length $n=\{126, 252, 504, 756\}$, and forecast period $m=\{21, 63\}$. Data is for the period July 2010 through December 2025, the period when there is complete data for all stocks and rates. For comparison, we show the results when forecasts are based on the individual datasets for Rates and Stocks, as well as when forecasts are based on the combination of both datasets. Predictions periods begin 3 years after the start of the dataset. (As expected the UV forecast errors do not change.) }}{5}{table.3}\protected@file@percent }
\newlabel{tab:uv-mv-combined}{{3}{5}{\small Combined dataset forecasts. UV vs.\ MV comparison by series (lower is better). Improvements are mean UV error minus mean MV error. Results are averaged across values of input length $n=\{126, 252, 504, 756\}$, and forecast period $m=\{21, 63\}$. Data is for the period July 2010 through December 2025, the period when there is complete data for all stocks and rates. For comparison, we show the results when forecasts are based on the individual datasets for Rates and Stocks, as well as when forecasts are based on the combination of both datasets. Predictions periods begin 3 years after the start of the dataset. (As expected the UV forecast errors do not change.)}{table.3}{}}
